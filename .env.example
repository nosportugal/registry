# MCP Registry Configuration

# Server configuration
MCP_REGISTRY_SERVER_ADDRESS=:8080
MCP_REGISTRY_VERSION=dev

# Database configuration
MCP_REGISTRY_DATABASE_URL=postgres://username:password@localhost:5432/mcp-registry

# Path or URL to import seed data (supports local files and HTTP URLs)
# For local file: data/seed.json
# For Apigee integration: data/seed.json (mounted volume)
# Note: Registry performs full reload on startup (clears DB and reimports)
MCP_REGISTRY_SEED_FROM=data/seed.json

# Enable registry validation during seed import (recommended: true)
MCP_REGISTRY_ENABLE_REGISTRY_VALIDATION=true

